<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAF9F8"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp"
        android:paddingBottom="80dp">

        <!-- App Title -->
        <TextView
            android:id="@+id/tvAppTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MindEase"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#B9A9D1"
            android:layout_marginTop="32dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Welcome Subtitle -->
        <TextView
            android:id="@+id/tvWelcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome!"
            android:textSize="20sp"
            android:textColor="#8B8B8B"
            android:layout_marginTop="16dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvAppTitle" />

        <!-- Instruction Text -->
        <TextView
            android:id="@+id/tvInstruction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌸 Choose your companion and give it a name"
            android:textSize="16sp"
            android:textColor="#A0A0A0"
            android:layout_marginTop="24dp"
            android:gravity="center"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvWelcome" />

        <!-- Pet Options Container -->
        <LinearLayout
            android:id="@+id/llPetOptions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="40dp"
            app:layout_constraintTop_toBottomOf="@id/tvInstruction"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Bird Option -->
            <LinearLayout
                android:id="@+id/llBird"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/pet_option_background_selected"
                android:padding="20dp"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"
                android:elevation="2dp">

                <ImageView
                    android:id="@+id/ivBird"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:src="@drawable/ic_bird"
                    android:tint="#A8D8EA" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🐦 Bird"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginTop="12dp"
                    android:textColor="#5A5A5A" />
            </LinearLayout>

            <!-- Dog Option -->
            <LinearLayout
                android:id="@+id/llDog"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/pet_option_background"
                android:padding="20dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:clickable="true"
                android:focusable="true"
                android:elevation="2dp">

                <ImageView
                    android:id="@+id/ivDog"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:src="@drawable/ic_dog"
                    android:tint="#C5D9D1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🐕 Dog"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginTop="12dp"
                    android:textColor="#5A5A5A" />
            </LinearLayout>

            <!-- Cat Option -->
            <LinearLayout
                android:id="@+id/llCat"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/pet_option_background"
                android:padding="20dp"
                android:layout_marginStart="8dp"
                android:clickable="true"
                android:focusable="true"
                android:elevation="2dp">

                <ImageView
                    android:id="@+id/ivCat"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:src="@drawable/ic_cat"
                    android:tint="#E8D5E4" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🐱 Cat"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginTop="12dp"
                    android:textColor="#5A5A5A" />
            </LinearLayout>

        </LinearLayout>

        <!-- Selected Companion Text -->
        <TextView
            android:id="@+id/tvCompanionSelected"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✨ Companion selected: None"
            android:textSize="14sp"
            android:textColor="#B9A9D1"
            android:layout_marginTop="28dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/llPetOptions" />

        <!-- Name Input Section -->
        <TextView
            android:id="@+id/tvNameLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💫 Name your companion:"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#5A5A5A"
            android:layout_marginTop="36dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvCompanionSelected" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:layout_constraintTop_toBottomOf="@id/tvNameLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:boxStrokeColor="#D5D5D5"
            app:hintTextColor="#B9A9D1">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etCompanionName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Enter a name..."
                android:textSize="16sp"
                android:textColor="#5A5A5A"
                android:textColorHint="#C0C0C0" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Example Hint -->
        <TextView
            android:id="@+id/tvExample"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✨ eg. Mochi, Luna, Oliver"
            android:textSize="12sp"
            android:textColor="#A8D8EA"
            android:layout_marginTop="8dp"
            android:layout_marginStart="12dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tilName" />

        <!-- Navigation Buttons -->
        <LinearLayout
            android:id="@+id/llButtons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="56dp"
            android:layout_marginBottom="32dp"
            app:layout_constraintTop_toBottomOf="@id/tvExample"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBack"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="← Back"
                android:textAllCaps="false"
                android:backgroundTint="#F0EBF5"
                android:textColor="#B9A9D1"
                app:cornerRadius="26dp"
                android:layout_marginEnd="8dp"
                app:strokeColor="#E8D5E4"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnContinue"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="Continue →"
                android:textAllCaps="false"
                android:backgroundTint="#C5D9D1"
                android:textColor="#5A6F66"
                app:cornerRadius="26dp"
                android:layout_marginStart="8dp" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>