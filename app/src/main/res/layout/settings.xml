<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F5F7FA">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Settings"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp" />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Notifications -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="space_between"
                android:layout_marginBottom="16dp">
                <TextView android:text="Notifications:" android:textSize="16sp" />
                <Switch />
            </LinearLayout>

            <!-- Companion Notifications -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="space_between"
                android:layout_marginBottom="16dp">
                <TextView android:text="Companion Notifications:" android:textSize="16sp" />
                <Switch />
            </LinearLayout>

            <!-- See Stats -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="space_between"
                android:layout_marginBottom="16dp">
                <TextView android:text="See Stats:" android:textSize="16sp" />
                <TextView android:text="→" android:textSize="20sp" android:textColor="#4A90E2" />
            </LinearLayout>

            <!-- Bug Reports -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="space_between"
                android:layout_marginBottom="16dp">
                <TextView android:text="Bug Reports:" android:textSize="16sp" />
                <TextView android:text="→" android:textSize="20sp" android:textColor="#4A90E2" />
            </LinearLayout>

            <!-- Themes -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="space_between"
                android:layout_marginBottom="16dp">
                <TextView android:text="Themes:" android:textSize="16sp" />
                <TextView android:text="→" android:textSize="20sp" android:textColor="#4A90E2" />
            </LinearLayout>

            <!-- View Journal History -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="space_between"
                android:layout_marginBottom="16dp">
                <TextView android:text="view journal history:" android:textSize="16sp" />
                <TextView android:text="→" android:textSize="20sp" android:textColor="#4A90E2" />
            </LinearLayout>

            <!-- View Entry History -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="space_between"
                android:layout_marginBottom="24dp">
                <TextView android:text="view entry history:" android:textSize="16sp" />
                <TextView android:text="→" android:textSize="20sp" android:textColor="#4A90E2" />
            </LinearLayout>

            <!-- Add Emergency Contact Button -->
            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Add Emergency Contact"
                android:backgroundTint="#D32F2F"
                android:layout_marginBottom="24dp" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginBottom="16dp" />

            <!-- Sign In -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sign In:"
                android:textSize="16sp"
                android:layout_marginBottom="12dp" />

            <!-- Sign Out -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sign Out"
                android:textSize="16sp"
                android:textColor="#D32F2F" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>